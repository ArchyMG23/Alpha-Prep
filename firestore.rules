rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} { allow read, write: if false; }

    // --- Helpers ---
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    function isValidQuestion(data) {
      return data.keys().hasAll(['id', 'testType', 'type', 'level', 'title', 'content']) &&
             data.testType in ['TCF', 'TEF', 'IELTS'] &&
             data.type in ['WRITING', 'READING', 'LISTENING', 'SPEAKING', 'METHODOLOGY'] &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 5000;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'role']) && 
             data.id is string &&
             data.role in ['USER', 'ADMIN'];
    }

    function isValidAccessKey(data) {
      return data.keys().hasAll(['key', 'type', 'isUsed']) &&
             data.key is string &&
             data.type in ['SUBSCRIPTION', 'CREDITS'] &&
             data.isUsed is bool;
    }

    // --- Collections ---

    // User Profiles (Identified by device ID)
    // Per user request: no Google Auth, so we allow access based on the ID in the path
    match /users/{userId} {
      allow get, create, update: if isValidId(userId);
      
      match /attempts/{attemptId} {
        allow read, write: if isValidId(userId);
      }
    }

    // Global Questions (Publicly readable, Admin writable)
    match /questions/{questionId} {
      allow read: if true;
      allow write: if isValidQuestion(incoming());
    }

    // Simulations (Publicly readable, Admin writable)
    match /simulations/{simId} {
      allow read: if true;
      allow write: if isValidId(simId) && incoming().keys().hasAll(['id', 'testType', 'title', 'questions']);
    }

    // Access Keys
    match /accessKeys/{key} {
      allow get, list: if true;
      allow create: if isValidAccessKey(incoming());
      allow update: if !existing().isUsed && incoming().isUsed == true;
    }

    // Admin List (Public read for client-side role check)
    match /admins/{userId} {
      allow read: if true;
      allow write: if false; 
    }

    // Settings (Prices)
    match /settings/prices {
      allow read: if true;
      allow write: if true; // Managed by Admin in hidden module
    }
  }
}
