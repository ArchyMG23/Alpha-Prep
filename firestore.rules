rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} { allow read, write: if false; }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'role']) && 
             data.id is string && data.email is string &&
             data.role in ['USER', 'ADMIN'];
    }

    function isValidQuestion(data) {
      return data.keys().hasAll(['id', 'testType', 'type', 'level', 'title', 'content']) &&
             data.testType in ['TCF', 'TEF', 'IELTS'] &&
             data.type in ['WRITING', 'READING', 'LISTENING', 'SPEAKING', 'METHODOLOGY'] &&
             data.level in ['A1', 'A2', 'B1', 'B2', 'C1', 'C2'] &&
             data.title is string && data.title.size() <= 500 &&
             data.content is string && data.content.size() <= 50000;
    }

    function isValidAccessKey(data) {
      return data.keys().hasAll(['key', 'type', 'isUsed', 'createdAt', 'expiresIfUnusedAt']) &&
             data.key is string && data.key.size() <= 64 &&
             data.type in ['SUBSCRIPTION', 'CREDITS'] &&
             data.isUsed is bool &&
             data.createdAt is string &&
             data.expiresIfUnusedAt is string;
    }

    // --- Collections ---

    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && (
        // Action: Self-Profile Update (Sync score/crs)
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'estimatedCRS', 'averageCLB', 'subscriptions', 'correctionCredits', 'creditsExpireAt'])) ||
        // Action: Admin Full Override
        isAdmin()
      );

      // User specific sub-collections
      match /attempts/{attemptId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidId(attemptId);
        allow write: if isAdmin();
      }
    }

    // Global Questions
    match /questions/{questionId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow write: if isAdmin() && isValidQuestion(incoming());
    }

    // Access Keys
    match /accessKeys/{key} {
      allow get: if isSignedIn();
      allow create: if isAdmin() && isValidAccessKey(incoming());
      allow update: if (isSignedIn() && !existing().isUsed && incoming().isUsed == true && (
          // Action: Activating a key (marking as used)
          incoming().diff(existing()).affectedKeys().hasOnly(['isUsed']) &&
          duration.value(timestamp(existing().expiresIfUnusedAt) - request.time, 's') > 0
        )) || isAdmin();
    }

    // Admin List (System Managed)
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }
  }
}
