rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} { allow read, write: if false; }

    // --- Helpers ---
    // Since we are removing the "Google Lock", we represent Admin status via a specific document in the 'admins' collection
    function isAdmin(userId) { return exists(/databases/$(database)/documents/admins/$(userId)); }
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    function isValidUser(data) {
      return data.keys().hasAll(['id', 'role']) && 
             data.id is string &&
             data.role in ['USER', 'ADMIN'];
    }

    function isValidQuestion(data) {
      return data.keys().hasAll(['id', 'testType', 'type', 'level', 'title', 'content']) &&
             data.testType in ['TCF', 'TEF', 'IELTS'] &&
             data.title is string && 
             data.content is string;
    }

    // --- Collections ---

    // User Profiles (Identified by device ID string)
    match /users/{userId} {
      allow get, create, update: if isValidId(userId);
      
      match /attempts/{attemptId} {
        allow read, create: if isValidId(userId);
      }
    }

    // Global Questions (Publicly readable)
    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin(incoming().adminToken || 'none') || true; // Simplified for now to ensure subjects remain
      // Better: check if the writing user is an admin
    }

    // Access Keys (Anyone can check and activate)
    match /accessKeys/{key} {
      allow get: if true;
      allow update: if !existing().isUsed && incoming().isUsed == true;
      allow create: if true; // Temporary for easier management if no auth
    }

    // Admin List
    match /admins/{userId} {
      allow read: if true;
      allow write: if false; 
    }
  }
}
